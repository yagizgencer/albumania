# Base URL of the backend API.
# Local dev: http://localhost:8000 (below).
# Production: MUST be set in the Vercel project settings to the Render API URL
# (e.g. https://albumania-api.onrender.com). If unset in a prod build the app
# falls back to localhost and logs a console error.
VITE_API_BASE_URL=http://localhost:8000
