DATABASE_URL=sqlite:///./albumania.db
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
CORS_ORIGINS=http://localhost:5173

# Transactional email (Resend). Leave RESEND_API_KEY empty in dev to log emails
# (including verification links) to the backend console instead of sending.
RESEND_API_KEY=
EMAIL_FROM=Albumania <onboarding@resend.dev>
FRONTEND_BASE_URL=http://localhost:5173
